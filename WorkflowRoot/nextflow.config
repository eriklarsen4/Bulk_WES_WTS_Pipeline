// nextflow.config

params {
    genome = 'GRCh38'
    reference_base = "${projectDir}/../genomicsshare/references"
    input_dirs = null
    analysis_type = 'wes'  // or 'wts' or 'both'

    // Allow users to override resource requests
    max_parallel_samples = null

    filter {
        min_median_mapping_quality = 35
        max_alt_allele_count = 3
    }

    genomes {
        'GRCh38' {
            fasta           = "${params.reference_base}/GRCh38/Homo_sapiens_assembly38.fasta"
            fasta_fai       = "${params.reference_base}/GRCh38/Homo_sapiens_assembly38.fasta.fai"
            dict            = "${params.reference_base}/GRCh38/Homo_sapiens_assembly38.dict"
            bwa_index       = "${params.reference_base}/GRCh38/bwa/hg38"
            gtf             = "${params.reference_base}/GRCh38/annotation/gencode.v47.annotation.gtf"
            star_index      = "${params.reference_base}/GRCh38/STAR"
            salmon_index    = "${params.reference_base}/GRCh38/salmon_index"
            dbsnp_vcf       = "${params.reference_base}/GRCh38/dbsnp/Homo_sapiens_assembly38.dbsnp138.vcf"
            dbsnp_tbi       = "${params.reference_base}/GRCh38/dbsnp/Homo_sapiens_assembly38.dbsnp138.vcf.idx"
            mills_vcf       = "${params.reference_base}/GRCh38/mills/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz"
            mills_tbi       = "${params.reference_base}/GRCh38/mills/Mills_and_1000G_gold_standard.indels.hg38.vcf.gz.tbi"
        }
    }
}

// ============================================================================
// PROCESS CONFIGURATION
// ============================================================================

process {
    stageInMode = 'copy'
    stageOutMode = 'rsync'

    // ============================================================================
    // RESOURCE ALLOCATION
    // Calibrated from single-sample testing
    // Memory set to 5 GB per CPU (common HPC minimum)
    // Users can override with --cpus, --memory flags if needed
    // ============================================================================

    withLabel: 'trim' {
        cpus = 8
        memory = '40 GB'
        time = '1h'
    }

    withLabel: 'fastq_to_sam' {
        cpus = 8
        memory = '40 GB'
        time = '1h'
    }

    withLabel: 'bwa_align' {
        cpus = 8
        memory = '40 GB'
        time = '1h'
    }

    withLabel: 'star_align' {
        cpus = 7
        memory = '64 GB'
        time = '2h'
    }

    withLabel: 'merge_bam' {
        cpus = 8
        memory = '40 GB'
        time = '1h'
    }

    withLabel: 'mark_duplicates' {
        cpus = 2
        memory = '10 GB'
        time = '1h'
    }

    withLabel: 'add_read_groups' {
        cpus = 8
        memory = '40 GB'
        time = '1h'
    }

    withLabel: 'bqsr' {
        cpus = 8
        memory = '40 GB'
        time = '2h'
    }

    withLabel: 'mutect2' {
        cpus = 8
        memory = '64 GB'
        time = '4h'
    }

    withLabel: 'filter_mutect' {
        cpus = 8
        memory = '40 GB'
        time = '2h'
    }

    withLabel: 'quantification' {
        cpus = 8
        memory = '40 GB'
        time = '2h'
    }

    withLabel: 'build_index' {
        cpus = 16
        memory = '80 GB'
        time = '12h'
    }
}

// ============================================================================
// PROFILES
// ============================================================================

profiles {
    // Default: local execution
    standard {
        process {
            executor = 'local'
            cpus = Math.min(8, Runtime.getRuntime().availableProcessors())
            memory = '4 GB'
        }
    }

    // SLURM HPC (generic, works on any SLURM cluster)
    slurm {
        process {
            executor = 'slurm'
            queue = 'standard'
            
            beforeScript = '''
                module purge
                module load gnu8/8.3.0
                module load bwa/0.7.17
                module load samtools/1.19.2
                module load picard/2.23.4
                module load gatk/4.2.5.0
                module load star/2.7.11b
                module load salmon/1.10.0
                module load trimgalore
                module load pigz/2.7
                module load R/4.1.0
                module load vcftools/0.1.16
                module load sratoolkit/3.1.1
    
                export PICARD_JAR=/opt/ohpc/pub/apps/picard/2.23.4/libs/picard.jar
                
                # Ensure R user library is in search path (for BQSR plots embedded in AnalyzeCovariates)
                export R_LIBS_USER="${HOME}/R/x86_64-pc-linux-gnu-library/4.1"
                export R_LIBS="${R_LIBS_USER}:/opt/ohpc/pub/apps/R/4.1.0/lib64/R/library"
            '''
            
            clusterOptions = {
                def account = System.getenv('SLURM_ACCOUNT')
                account ? "--account=${account}" : ""
            }
        }
    
        executor {
            queueSize = 50
            submitRateLimit = '10 sec'
        }
    }

    // Container execution (generic, works anywhere)
    singularity {
        singularity {
            enabled = true
            autoMounts = true
        }

        process.container = 'docker://your-org/nextflow_wes_wts:latest'
    }

    docker {
        docker {
            enabled = true
            runOptions = '--rm'
        }

        process.container = 'your-org/nextflow_wes_wts:latest'
    }

    // Development/testing profile
    test {
        process {
            executor = 'local'
            cpus = 2
            memory = '4 GB'
            time = '15m'

            withLabel: 'bwa_align' {
                cpus = 2
                memory = '4 GB'
            }

            withLabel: 'star_align' {
                cpus = 2
                memory = '4 GB'
            }
        }
    }
}

// ============================================================================
// REPORTING
// ============================================================================

report {
    enabled = true
    file = 'results/reports/execution_report.html'
}

timeline {
    enabled = true
    file = 'results/reports/timeline.html'
}

trace {
    enabled = true
    file = 'results/reports/trace.txt'
    fields = 'task_id,name,status,exit,submit,start,complete,duration,realtime,cpus,memory,%cpu,%mem,rss,vmem'
}

manifest {
    name = 'WES-WTS-Nextflow'
    author = 'Erik Larsen'
    description = 'Whole Exome and Whole Transcriptome Sequencing Pipeline'
    version = '1.0.0'
    mainScript = 'main.nf'
    nextflowVersion = '>=22.10.0'
}